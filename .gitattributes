# Normalise les fins de ligne entre machines (Win/Mac/Linux)
* text=auto eol=lf

# Fichiers binaires (pas de conversion de fins de ligne)
*.png binary
*.jpg binary
*.jpeg binary
*.bin binary
*.glb binary
*.woff binary
*.woff2 binary

# Scripts Windows en CRLF
*.cmd text eol=crlf
*.bat text eol=crlf
